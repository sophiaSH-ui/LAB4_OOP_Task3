<Window x:Class="lab4_task3.views.CreatingAccountOwner"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новий власник" Height="680" Width="460" 
        MinHeight="680" MinWidth="460"
        MaxHeight="680" MaxWidth="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource CreamBrush}">
 
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource DarkGreenBrush}" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource LightGreenBrush}" FontSize="22"
                        Cursor="Hand" Click="BtnBack_Click" Margin="0,0,16,0" Content="←" Height="48" VerticalAlignment="Top"/>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="НОВИЙ ВЛАСНИК"
                               FontFamily="Segoe UI Semibold"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource LightGreenBrush}"/>
                        <TextBlock Text="Додавання запису до бази"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource MutedGreenBrush}"
                               Margin="0,4,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="👤" FontSize="36" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,24,24,16">
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Прізвище" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtLastName" Style="{StaticResource InputBox}" Margin="0,0,0,16"/>

                            <TextBlock Text="Ім'я" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtFirstName" Style="{StaticResource InputBox}" Margin="0,0,0,16"/>

                            <TextBlock Text="Дата народження" Style="{StaticResource FieldLabel}"/>
                            <DatePicker x:Name="DpBirthDate" Style="{StaticResource InputDate}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="White" Padding="24,14" BorderBrush="{StaticResource LightGreenBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" Content="✓ Зберегти"/>
                    <Button Grid.Column="2" Style="{StaticResource DangerButton}" Click="BtnReset_Click" Content="↺ Очистити"/>
                </Grid>
            </Border>
        </Grid>

</Window>