<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="lab4_task3.MainWindow"
        Title="Земельні ділянки" Height="680" Width="460"
        MinHeight="680" MinWidth="460"
        MaxHeight="680" MaxWidth="460"

        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource CreamBrush}">

    <Grid Margin="0,0,0,3">
        <Grid.RowDefinitions>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource DarkGreenBrush}"
                CornerRadius="0,0,40,40" Margin="0,0,0,200" Grid.RowSpan="2">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center" Height="245">
                <TextBlock Text="🗺"
                           FontSize="80"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="ЗЕМЕЛЬНІ ДІЛЯНКИ"
                           FontFamily="Segoe UI Semibold"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource LightGreenBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Margin="40,30,40,0"
                VerticalAlignment="Top">
            <StackPanel Margin="0,10,0,0">

                <Button x:Name="BtnAddOwner"
                        Style="{StaticResource OwnerButton}"
                        Margin="0,0,0,15"
                        Click="BtnAddOwner_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="+ " FontSize="20" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Додати власника" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnAddLandPlot"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,20"
                        Click="BtnLReg_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🗺 " FontSize="18" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Земельний реєстр" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Background="{StaticResource LightGreenBrush}"
                           Margin="20,0,20,15"/>

                <Button x:Name="BtnExit"
                        Style="{StaticResource DangerButton}"
                        Height="42"
                        Click="BtnExit_Click">
                    <TextBlock Text="Вихід" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="© Земля, рідна земля..."
                   FontFamily="Segoe UI"
                   FontSize="12"
                   Foreground="{StaticResource MutedGreenBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
</Window>