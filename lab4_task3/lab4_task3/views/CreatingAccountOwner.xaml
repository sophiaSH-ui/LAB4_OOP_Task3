<Window x:Class="lab4_task3.views.CreatingAccountOwner"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Керування власниками" Height="780" Width="520" 
        MinHeight="780" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CreamBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource DarkGreenBrush}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource LightGreenBrush}" FontSize="22"
                        Cursor="Hand" Click="BtnBack_Click" Margin="0,0,16,0" Content="←" Height="48" VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="ВЛАСНИКИ" FontFamily="Segoe UI Semibold" FontSize="20" FontWeight="Bold" Foreground="{StaticResource LightGreenBrush}"/>
                    <TextBlock Text="Додавання та керування" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource MutedGreenBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="👤" FontSize="36" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <StackPanel Grid.Row="1" Margin="24,24,24,10">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Прізвище" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtLastName" Style="{StaticResource InputBox}" Margin="0,0,0,16"/>
                    <TextBlock Text="Ім'я" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="TxtFirstName" Style="{StaticResource InputBox}" Margin="0,0,0,16"/>
                    <TextBlock Text="Дата народження" Style="{StaticResource FieldLabel}"/>
                    <DatePicker x:Name="DpBirthDate" Style="{StaticResource InputDate}" Margin="0,0,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnSave" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" Content="✓ Зберегти"/>
                        <Button Grid.Column="2" Style="{StaticResource DangerButton}" Click="BtnReset_Click" Content="↺ Очистити"/>
                        <Button Grid.Column="4" x:Name="BtnDelete" Style="{StaticResource DangerButton}" Click="BtnDelete_Click" Content="🗑 Видалити" IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
        <DataGrid Grid.Row="2" x:Name="DgOwners" Background="White" BorderThickness="0"
                  Margin="24,10,24,24" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="DgOwners_SelectionChanged"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource LightGreenBrush}"
                  RowBackground="White" AlternatingRowBackground="{StaticResource CreamBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding ID}" Width="50"/>
                <DataGridTextColumn Header="Прізвище" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Ім'я" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Дата народження" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>