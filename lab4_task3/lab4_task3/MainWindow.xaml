<Window x:Class="lab4_task3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Земельні ділянки" Height="660" Width="460"
        MaxHeight="660" MaxWidth="460"
        MinHeight="660" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource CreamBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="240"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource DarkGreenBrush}"
                CornerRadius="0,0,50,50">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="300">
                <TextBlock Text="🗺"
                           FontSize="52"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="ЗЕМЕЛЬНІ ДІЛЯНКИ"
                           FontFamily="Segoe UI Semibold"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource LightGreenBrush}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Оберіть населений пункт:" 
                           Style="{StaticResource FieldLabel}" 
                           Foreground="{StaticResource MutedGreenBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,4"/>
                <ComboBox x:Name="CbLocation" 
                          Style="{StaticResource InputCombo}"
                          IsEditable="True"
                          Text="Почніть вводити назву..."
                          Margin="0,0,0,0">
                    <ComboBoxItem Content="Київ"/>
                    <ComboBoxItem Content="Львів"/>
                    <ComboBoxItem Content="Одеса"/>
                    <ComboBoxItem Content="Дніпро"/>
                    <ComboBoxItem Content="Харків"/>
                    <ComboBoxItem Content="Черкаси"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Margin="32,24,32,0"
                VerticalAlignment="Top">
            <StackPanel>
                <Border Background="{StaticResource CreamBrush}"
                        CornerRadius="8"
                        Padding="12,8"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Всього ділянок: "
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   Foreground="{StaticResource MutedGreenBrush}"/>
                        <TextBlock x:Name="CountText"
                                   Text="0"
                                   FontFamily="Segoe UI Semibold"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrightGreenBrush}"/>
                    </StackPanel>
                </Border>

                <Button x:Name="BtnAdd"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,10"
                        Click="BtnAdd_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+ " FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="Додати земельну ділянку"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnView"
                        Style="{StaticResource AccentButton}"
                        Margin="0,0,0,10"
                        Click="BtnView_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍 " FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Переглянути ділянки"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Background="{StaticResource LightGreenBrush}"
                           Margin="0,4,0,10"/>

                <Button x:Name="BtnExit"
                        Style="{StaticResource DangerButton}"
                        Height="42"
                        Click="BtnExit_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Вихід" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="© Земельний реєстр"
                   FontFamily="Segoe UI"
                   FontSize="11"
                   Foreground="{StaticResource MutedGreenBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
</Window>
