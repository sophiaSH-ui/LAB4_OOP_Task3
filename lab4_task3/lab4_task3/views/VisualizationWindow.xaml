<Window x:Class="lab4_task3.VisualizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Візуалізація ділянки" Height="700" Width="640"
        MinHeight="700" MinWidth="640"
        MaxHeight="700" MaxWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CreamBrush}">

    <Grid Width="640" Margin="0,0,0,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource DarkGreenBrush}" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource LightGreenBrush}" FontSize="22"
                            Cursor="Hand" Click="BtnBack_Click" Margin="0,0,16,0" Content="←" Height="48" VerticalAlignment="Top"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="КАРТА ДІЛЯНКИ" FontFamily="Segoe UI Semibold" FontSize="20" FontWeight="Bold" Foreground="{StaticResource LightGreenBrush}"/>
                    <TextBlock Text="Перегляд меж та характеристик об'єкта" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource MutedGreenBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="🗺" FontSize="36" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,16,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ДЕТАЛІ ДІЛЯНКИ" Style="{StaticResource SectionHeader}"/>
                    <WrapPanel Margin="0,8,0,0">
                        <StackPanel Margin="0,0,32,12">
                            <TextBlock Text="Власник:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="TxtOwner" Text="—" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DarkGreenBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,32,12">
                            <TextBlock Text="Розташування:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="TxtLocation" Text="—" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DarkGreenBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,32,12">
                            <TextBlock Text="Призначення:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="TxtPurpose" Text="—" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DarkGreenBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,32,12">
                            <TextBlock Text="Тип ґрунту:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="TxtSoil" Text="—" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DarkGreenBrush}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Ринкова вартість:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="TxtPrice" Text="—" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DarkGreenBrush}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <Grid Background="#E8ECE1">
                    <TextBlock Text="Для масштабування: коліщатко миші | Для переміщення: затисніть ЛКМ" 
                                   FontSize="11" Foreground="{StaticResource MutedGreenBrush}" 
                                   HorizontalAlignment="Center" Margin="0,12,0,0" VerticalAlignment="Top" Panel.ZIndex="1"/>

                    <Canvas x:Name="MapCanvas" 
                                MouseWheel="MapCanvas_MouseWheel"
                                MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                                MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp"
                                MouseMove="MapCanvas_MouseMove"
                                Background="Transparent"
                                Cursor="SizeAll">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="MapScale"/>
                                <TranslateTransform x:Name="MapTranslate"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>

                    <Button Style="{StaticResource AccentButton}" Content="Відцентрувати мапу" 
                                Width="165" Height="36" FontSize="12" Padding="0"
                                HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,16"
                                Click="BtnResetMap_Click" Panel.ZIndex="2"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>